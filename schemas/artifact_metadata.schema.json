{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact_metadata.schema.json",
  "title": "Artifact Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "study_id",
    "run_id",
    "schema_version",
    "method_version",
    "tool_name",
    "tool_version",
    "generated_at",
    "input_hash",
    "artifact_hash",
    "warnings"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^artifact_[a-z0-9_]+$"
    },
    "artifact_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "study_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_]+$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "method_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tool_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "tool_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "warning.schema.json"
      }
    }
  }
}
