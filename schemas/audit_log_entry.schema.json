{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit_log_entry.schema.json",
  "title": "Audit Log Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp",
    "study_id",
    "run_id",
    "tool_name",
    "tool_version",
    "method_version",
    "schema_version",
    "input_hash",
    "output_hash",
    "status",
    "duration_ms",
    "seed",
    "artifact_paths",
    "warnings",
    "errors"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "study_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_]+$"
    },
    "tool_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "tool_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "method_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "output_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": ["success", "success_with_warnings", "failed_validation", "failed_runtime", "skipped"]
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "seed": {
      "type": ["integer", "null"]
    },
    "artifact_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "warning.schema.json"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "error.schema.json"
      }
    }
  }
}
