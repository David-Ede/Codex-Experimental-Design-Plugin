{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "error.schema.json",
  "title": "DOE Toolchain Error",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "message", "recoverable"],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "field": {
      "type": ["string", "null"]
    },
    "recoverable": {
      "type": "boolean"
    },
    "details": {
      "type": "object"
    }
  }
}
