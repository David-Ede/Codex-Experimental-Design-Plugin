{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "design_comparison.schema.json",
  "title": "Design Comparison",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "comparison_id",
    "candidate_set_id",
    "selected_candidate_design_ids",
    "active_metrics",
    "preferred_candidate_design_id",
    "user_selected_candidate_design_id",
    "decision_notes",
    "generated_at"
  ],
  "properties": {
    "comparison_id": {
      "type": "string",
      "pattern": "^comparison_[a-z0-9_]+$"
    },
    "candidate_set_id": {
      "type": "string",
      "pattern": "^candidate_set_[a-z0-9_]+$"
    },
    "selected_candidate_design_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^candidate_[a-z0-9_]+$"
      }
    },
    "active_metrics": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
      }
    },
    "preferred_candidate_design_id": {
      "type": ["string", "null"],
      "pattern": "^candidate_[a-z0-9_]+$"
    },
    "user_selected_candidate_design_id": {
      "type": ["string", "null"],
      "pattern": "^candidate_[a-z0-9_]+$"
    },
    "decision_notes": {
      "type": ["string", "null"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}

