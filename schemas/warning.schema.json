{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "warning.schema.json",
  "title": "DOE Toolchain Warning",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "severity", "message"],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*[a-z0-9]$"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "blocking"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "field": {
      "type": ["string", "null"]
    },
    "details": {
      "type": "object"
    }
  }
}
